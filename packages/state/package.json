{
  "name": "@hermests/state",
  "version": "0.0.1",
  "description": "SQLite session store, FTS5 search, and message persistence for HermesTS",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
