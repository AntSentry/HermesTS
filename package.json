{
  "name": "hermests",
  "version": "0.0.1",
  "description": "TypeScript port of NousResearch/hermes-agent — faithful, fully-tested port.",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^2.1.8",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20",
    "bun": ">=1.1"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/AntSentry/HermesTS.git"
  }
}
